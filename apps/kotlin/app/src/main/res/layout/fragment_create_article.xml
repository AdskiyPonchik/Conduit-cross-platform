<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <EditText
            android:id="@+id/articleTitleTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Article Title"
            android:inputType="text" />

        <EditText
            android:id="@+id/articleDesciptionTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What's this article about?"
            android:inputType="text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Markdown" />

        <EditText
            android:id="@+id/articleBodyTv"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:gravity="top|start"
            android:hint="Write your article (in markdown)"
            android:inputType="textMultiLine"
            android:minLines="6"
            android:maxLines="10"
            android:scrollbars="vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Preview" />

        <WebView
            android:id="@+id/previewWebView"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="#00000000" />

            <Button
                android:id="@+id/uploadImageButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Upload image" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Images in this article" />

            <TextView
                android:id="@+id/uploadedImagesTextView"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:maxLines="4"
                android:padding="4dp"
                android:scrollbars="vertical"
                android:text="No images yet"
                android:textIsSelectable="true" />

        <EditText
            android:id="@+id/articleTagTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter tags"
            android:inputType="text" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/submitButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:text="Publish Article" />
</LinearLayout>
